# 이 파일을 복사해서 같은 폴더에 ".env" 라는 이름으로 저장하세요.
#   cp tts/.env.example tts/.env
# 그런 다음 아래 따옴표 안에 본인 키를 붙여넣으면 됩니다.
# ".env" 파일은 .gitignore에 등록되어 깃에 올라가지 않습니다.

# --- ElevenLabs 사용 시 ---
ELEVENLABS_API_KEY=여기에_ElevenLabs_키를_붙여넣기

# --- Google Cloud TTS 사용 시 (서비스 계정 JSON 파일의 경로) ---
# GOOGLE_APPLICATION_CREDENTIALS=/Users/내이름/keys/google-tts.json
